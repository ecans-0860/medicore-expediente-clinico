generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Rol {
  id_rol      Int      @id @default(autoincrement())
  nombre      String   @unique @db.VarChar(100)
  descripcion String?
  estado      String   @default("ACTIVO") @db.VarChar(20)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  usuarios Usuario[]
}

model Usuario {
  id_usuario      Int       @id @default(autoincrement())
  id_rol          Int
  id_paciente     Int?      @unique
  nombre_completo String    @db.VarChar(150)
  correo          String    @unique @db.VarChar(150)
  password_hash   String    @db.VarChar(255)
  estado          String    @default("ACTIVO") @db.VarChar(20)
  ultimo_acceso   DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  rol       Rol                 @relation(fields: [id_rol], references: [id_rol])
  paciente  Paciente?           @relation(fields: [id_paciente], references: [id_paciente])
  consultas ConsultaMedica[]
  citas     CitaMedica[]
  bitacoras BitacoraActividad[]

  @@index([id_rol])
  @@index([id_paciente])
}

model Paciente {
  id_paciente Int @id @default(autoincrement())

  nombres          String    @db.VarChar(100)
  apellidos        String    @db.VarChar(100)
  dpi              String    @unique @db.VarChar(20)
  fecha_nacimiento DateTime?
  sexo             String?   @db.VarChar(20)

  telefono  String? @db.VarChar(20)
  correo    String? @db.VarChar(150)
  direccion String? @db.VarChar(255)

  tipo_sangre  String? @db.VarChar(10)
  estado_civil String? @db.VarChar(30)
  ocupacion    String? @db.VarChar(100)

  contacto_emergencia_nombre     String? @db.VarChar(150)
  contacto_emergencia_telefono   String? @db.VarChar(20)
  contacto_emergencia_parentesco String? @db.VarChar(50)

  aseguradora   String? @db.VarChar(100)
  numero_seguro String? @db.VarChar(100)

  observaciones String?

  fecha_registro DateTime @default(now())
  estado         String   @default("ACTIVO") @db.VarChar(20)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  expediente ExpedienteClinico?
  citas      CitaMedica[]
  usuario    Usuario?

  @@index([nombres])
  @@index([apellidos])
  @@index([dpi])
  @@index([estado])
  @@index([fecha_registro])
}

model ExpedienteClinico {
  id_expediente     Int      @id @default(autoincrement())
  id_paciente       Int      @unique
  numero_expediente String   @unique @db.VarChar(50)
  fecha_apertura    DateTime @default(now())
  motivo_apertura   String?
  estado            String   @default("ACTIVO") @db.VarChar(20)
  observaciones     String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  paciente     Paciente            @relation(fields: [id_paciente], references: [id_paciente])
  consultas    ConsultaMedica[]
  antecedentes AntecedenteMedico[]
  alergias     Alergia[]

  @@index([id_paciente])
  @@index([numero_expediente])
}

model ConsultaMedica {
  id_consulta       Int @id @default(autoincrement())
  id_expediente     Int
  id_usuario_medico Int

  fecha_consulta DateTime @default(now())

  motivo            String
  enfermedad_actual String?
  examen_fisico     String?
  impresion_clinica String?
  plan_medico       String?

  observaciones String?

  signos_vitales          String?
  peso                    String? @db.VarChar(20)
  talla                   String? @db.VarChar(20)
  presion_arterial        String? @db.VarChar(20)
  temperatura             String? @db.VarChar(20)
  frecuencia_cardiaca     String? @db.VarChar(20)
  frecuencia_respiratoria String? @db.VarChar(20)
  saturacion_oxigeno      String? @db.VarChar(20)

  tipo_consulta String? @db.VarChar(50)
  estado        String  @default("ACTIVA") @db.VarChar(20)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  expediente    ExpedienteClinico @relation(fields: [id_expediente], references: [id_expediente])
  usuarioMedico Usuario           @relation(fields: [id_usuario_medico], references: [id_usuario])

  diagnosticos Diagnostico[]
  tratamientos Tratamiento[]
  recetas      RecetaMedica[]

  @@index([id_expediente])
  @@index([id_usuario_medico])
  @@index([fecha_consulta])
  @@index([estado])
}

model AntecedenteMedico {
  id_antecedente Int      @id @default(autoincrement())
  id_expediente  Int
  tipo           String   @db.VarChar(100)
  descripcion    String
  fecha_registro DateTime @default(now())
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  expediente ExpedienteClinico @relation(fields: [id_expediente], references: [id_expediente])

  @@index([id_expediente])
}

model Alergia {
  id_alergia     Int      @id @default(autoincrement())
  id_expediente  Int
  sustancia      String   @db.VarChar(150)
  descripcion    String?
  severidad      String?  @db.VarChar(50)
  fecha_registro DateTime @default(now())
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  expediente ExpedienteClinico @relation(fields: [id_expediente], references: [id_expediente])

  @@index([id_expediente])
}

model Diagnostico {
  id_diagnostico Int      @id @default(autoincrement())
  id_consulta    Int
  descripcion    String
  tipo           String?  @db.VarChar(100)
  observaciones  String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  consulta ConsultaMedica @relation(fields: [id_consulta], references: [id_consulta])

  @@index([id_consulta])
}

model Tratamiento {
  id_tratamiento Int       @id @default(autoincrement())
  id_consulta    Int
  descripcion    String
  indicaciones   String?
  fecha_inicio   DateTime?
  fecha_fin      DateTime?
  estado         String    @default("ACTIVO") @db.VarChar(20)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  consulta ConsultaMedica @relation(fields: [id_consulta], references: [id_consulta])

  @@index([id_consulta])
}

model RecetaMedica {
  id_receta     Int      @id @default(autoincrement())
  id_consulta   Int
  fecha_emision DateTime @default(now())
  indicaciones  String?
  medicamentos  String
  observaciones String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  consulta ConsultaMedica @relation(fields: [id_consulta], references: [id_consulta])

  @@index([id_consulta])
}

model CitaMedica {
  id_cita       Int      @id @default(autoincrement())
  id_paciente   Int
  id_usuario    Int?
  fecha_hora    DateTime
  motivo        String
  estado        String   @default("PENDIENTE") @db.VarChar(30)
  observaciones String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  paciente Paciente @relation(fields: [id_paciente], references: [id_paciente])
  usuario  Usuario? @relation(fields: [id_usuario], references: [id_usuario])

  @@index([id_paciente])
  @@index([id_usuario])
  @@index([fecha_hora])
}

model BitacoraActividad {
  id_bitacora Int      @id @default(autoincrement())
  id_usuario  Int
  accion      String   @db.VarChar(150)
  descripcion String?
  modulo      String?  @db.VarChar(100)
  fecha_hora  DateTime @default(now())
  ip_origen   String?  @db.VarChar(45)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  usuario Usuario @relation(fields: [id_usuario], references: [id_usuario])

  @@index([id_usuario])
  @@index([fecha_hora])
}
